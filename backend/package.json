{
  "name": "orufy-backend",
  "version": "1.0.0",
  "description": "Backend for Orufy - Express + MongoDB + JWT + Resend + Cloudinary",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --exec node src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed/seed.js",
    "lint": "eslint . --ext .js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cloudinary": "^1.32.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "mongoose": "^7.3.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^4.0.0",
    "resend": "^6.12.3",
    "jsonwebtoken": "^9.0.0",
    "xss-clean": "^0.1.1",
    "express-mongo-sanitize": "^2.2.0"
